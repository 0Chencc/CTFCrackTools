{
  "name": "ctfcracktools-x",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:complexity": "eslint . --rule 'complexity: [error, 15]' --rule 'max-depth: [error, 4]' --rule 'max-lines-per-function: [error, 100]'",
